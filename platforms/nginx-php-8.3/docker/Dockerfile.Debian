## Sources to build the container
FROM php:8.3-fpm-bookworm-slim

ARG UID
ARG GID
ENV UID=${UID}
ENV GID=${GID}
ARG USER
ARG GROUP
ENV USER=${USER}
ENV GROUP=${GROUP}

ENV DEBIAN_FRONTEND=noninteractive

## Setup container custom user and group
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    sudo \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -g ${GID} ${GROUP} \
    && useradd -m -u ${UID} -g ${GROUP} -s /bin/bash ${USER} \
    && echo "${USER} ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

## OS packages required
RUN apt-get update && apt-get install -y --no-install-recommends \
    systemd \
    curl \
    wget \
    openssl \
    ca-certificates \
    nginx \
    ## OS extras
    make \
    git \
    nano \
    #zip \
    #unzip \
    #ffmpeg \
    ## Process Control System
    supervisor \
    ## Cron
    cron \
    && rm -rf /var/lib/apt/lists/*

## Build dependencies for PHP extensions
RUN apt-get update && apt-get install -y --no-install-recommends \
    $PHPIZE_DEPS \
    libzip-dev \
    libfreetype6-dev \
    libicu-dev \
    #libmcrypt-dev \
    libjpeg62-turbo-dev \
    libpng-dev \
    libxslt1-dev \
    patch \
    openssh-client \
    libxml2-dev \
    libcurl4-openssl-dev \
    libonig-dev \
    libssl-dev \
    ## SQLite
    libsqlite3-dev \
    ## Mysql - Mariadb
    #default-libmysqlclient-dev \
    ## Postgre
    libpq-dev \
    ## MongoDB (for PECL extension)
    #pkg-config \
    #libssl-dev \
    ## RabbitMQ / AMQP
    #librabbitmq-dev \
    && rm -rf /var/lib/apt/lists/*

## Configure and install PHP GD extension
RUN docker-php-ext-configure gd --with-freetype --with-jpeg

## PHP required extensions from Docker
RUN docker-php-ext-install -j$(nproc) \
    pdo \
    ## SQLite
    pdo_sqlite \
    ## Mysql - Mariadb
    #pdo_mysql \
    #mysqli \
    ## Postgre
    pdo_pgsql \
    pgsql \
    ## Other extensions
    zip \
    bcmath \
    intl \
    gd \
    soap \
    xsl \
    sockets \
    ## Process Control (jobs)
    pcntl \
    opcache

## Install amqp via PECL for clients that use the native ext-amqp like RabbitMQ
#RUN apt-get update && apt-get install -y --no-install-recommends librabbitmq-dev \
#    && rm -rf /var/lib/apt/lists/* \
#    && pecl install amqp \
#    && docker-php-ext-enable amqp \
#    && php -m | grep -i amqp

## Install MongoDB extension from PECL
#RUN pecl install mongodb-2.1.0 \
#    && docker-php-ext-enable mongodb

## Install Redis extension from PECL
#RUN pecl install redis \
#    && docker-php-ext-enable redis

## Install XDebug from PECL
#RUN pecl install xdebug \
#    && docker-php-ext-enable xdebug

## Clean up build dependencies to reduce image size
RUN apt-get purge -y --auto-remove -o APT::AutoRemove::RecommendsImportant=false \
    $PHPIZE_DEPS \
    libzip-dev \
    libfreetype6-dev \
    libicu-dev \
    libjpeg62-turbo-dev \
    libpng-dev \
    libxslt1-dev \
    libxml2-dev \
    libcurl4-openssl-dev \
    libonig-dev \
    libsqlite3-dev \
    libpq-dev

## Configure NGINX and remove created its default html directory
COPY config/nginx/nginx.conf /etc/nginx/nginx.conf
COPY config/nginx/conf.d /etc/nginx/conf.d/
RUN rm -rf /var/www/html

## Configure PHP-FPM
COPY config/php/conf.d/fpm-pool.conf /usr/local/etc/php-fpm.d/www.conf
COPY config/php/conf.d/php.ini /usr/local/etc/php/conf.d/custom.ini

## Configure Supervisor
COPY config/supervisor/supervisord.conf /etc/supervisor/supervisord.conf
COPY config/supervisor/conf.d/. /etc/supervisor/conf.d/

## Create predefined Crontab and apply file permissions
COPY config/crontab /var/spool/cron/crontabs/root
RUN chmod 0644 /var/spool/cron/crontabs/root

## PHP Composer
COPY --from=composer:latest /usr/bin/composer /usr/local/bin/composer

## Configure XDebug - (optional - uncomment line to use it)
#COPY config/php/xdebug.ini /usr/local/etc/php/conf.d/xdebug.ini

## Create project root and set it as work directory
RUN mkdir -p /var/www
WORKDIR /var/www

## Add application from docker-compose.yml -> volumes: source
COPY --chown=${USER}:${GROUP} ../ /var/www

## Remove unused directories
RUN rm -rf /var/www/html /var/www/localhost

## Make sure files/folders needed by the processes are accessible when they run under the user
RUN chown -R ${USER}:${GROUP} /var/www /run /var/lib/nginx /var/log/nginx

## Switch to use a non-root user from here on
USER ${USER}

## Expose as many ports as required - NGINX: 80 / Xdebug: 9003
EXPOSE 80

## Let supervisord start nginx & php-fpm
CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/supervisord.conf"]
